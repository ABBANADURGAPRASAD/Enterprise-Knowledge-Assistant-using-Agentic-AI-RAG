# IDE
.idea/
*.iml
.vscode/
*.swp
*.swo
.project
.classpath
.settings/

# Environment / Secrets
.env
.env.*
*.pem
*.key
application-local.yml
application-dev.yml

# OS
.DS_Store
Thumbs.db

# Docker volumes
docker/data/

# Vector store backups
vector-store/backups/

# Logs
*.log
logs/

# Test coverage
coverage/
.nyc_output/

# Temporary
tmp/
temp/
